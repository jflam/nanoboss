{
  "name": "nanoboss",
  "module": "nanoboss.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "nanoboss": "bun run nanoboss.ts",
    "build": "bun run build.ts",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "test": "bun run scripts/compact-test.ts",
    "test:raw": "bun test",
    "test:unit": "bun run scripts/compact-test.ts tests/unit",
    "test:e2e": "bun run scripts/compact-test.ts tests/e2e",
    "cleanup:sessions": "bun run scripts/cleanup-sessions.ts",
    "test:e2e:real": "NANOBOSS_RUN_E2E=1 bun run scripts/compact-test.ts tests/e2e",
    "prepare": "ts-patch install"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.1",
    "@mariozechner/pi-tui": "0.65.2",
    "@ryoppippi/unplugin-typia": "^2.6.5",
    "@typia/transform": "^12.0.1",
    "cli-highlight": "^2.1.11",
    "markdansi": "^0.2.1",
    "typia": "^12.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "ts-patch": "^3.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
