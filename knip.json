{
  "$schema": "./node_modules/knip/schema.json",
  "include": [
    "files",
    "exports",
    "types"
  ],
  "ignoreIssues": {
    "packages/adapters-mcp/src/stdio-jsonrpc.ts": [
      "exports",
      "types"
    ],
    "packages/adapters-mcp/src/registration.ts": [
      "exports"
    ],
    "packages/adapters-mcp/src/server.ts": [
      "exports"
