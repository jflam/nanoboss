{
  "$schema": "./node_modules/knip/schema.json",
  "entry": [
    "nanoboss.ts",
    "cli.ts",
    "resume.ts",
    "build.ts",
    "preload.ts",
    "scripts/**/*.ts",
    "packages/*/src/index.ts",
    "packages/app-runtime/src/runtime-service.ts",
    "procedures/**/*.ts",
    "src/runtime/service.ts"
  ],
  "include": [
    "files",
    "exports",
    "types"
  ],
  "ignoreIssues": {
    "packages/adapters-mcp/src/stdio-jsonrpc.ts": [
      "exports",
      "types"
    ],
    "packages/adapters-mcp/src/registration.ts": [
      "exports"
    ],
    "packages/adapters-mcp/src/server.ts": [
      "exports"
    ],
    "packages/adapters-tui/src/controller.ts": [
      "types"
    ],
    "packages/app-runtime/src/runtime-service.ts": [
      "exports"
    ],
    "packages/adapters-tui/src/form-renderers.ts": [
      "exports"
    ],
    "packages/adapters-acp-server/src/server.ts": [
      "exports"
    ],
    "packages/adapters-http/src/server-supervisor.ts": [
      "exports"
    ],
    "packages/adapters-http/src/server.ts": [
      "exports"
    ],
    "packages/procedure-catalog/src/names.ts": [
      "exports"
    ]
  },
  "project": [
    "*.ts",
    "scripts/**/*.ts",
    "packages/**/*.ts",
    "procedures/**/*.ts",
    "src/**/*.ts"
  ],
  "ignore": [
    "dist/**",
    "coverage/**",
    "tests/**",
    "packages/*/tests/**",
    "packages/procedure-sdk/test-fixtures/consumer/index.ts"
  ]
}
